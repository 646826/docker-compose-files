# Local DNS suffix. *.localhost works in modern browsers on the same machine.
# Resource prefix used by the Compose project, explicit networks, and volumes.
HOMELAB_PROJECT_NAME=homelab

# Bind HTTP to all interfaces by default. Runtime CI overrides this to 127.0.0.1.
HTTP_HOST_IP=0.0.0.0
BASE_DOMAIN=localhost
HTTP_PORT=80
# Bind MQTT to all interfaces by default. IoT runtime CI overrides this to 127.0.0.1.
MQTT_HOST_IP=0.0.0.0
MQTT_PORT=1883
TZ=Etc/UTC
TRAEFIK_LOG_LEVEL=INFO

# Non-secret service settings.
TRAEFIK_USERNAME=admin
GRAFANA_ADMIN_USER=admin
INFLUXDB_USERNAME=admin
INFLUXDB_ORG=home-org
INFLUXDB_BUCKET=home-bucket
# 0 keeps data indefinitely. Examples: 30d, 52w.
INFLUXDB_RETENTION=0
MOSQUITTO_USERNAME=home
OPENHAB_UID=9001
OPENHAB_GID=9001
NETDATA_HOSTNAME=homelab

# Used by `make k6`; the default targets the internal whoami service.
K6_TARGET_URL=http://whoami
